@@ -0,0 +1,59 @@
+# SPDX-License-Identifier: GPL-2.0-only OR BSD-2-Clause
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/input/touchscreen/solomon,ssd2092.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Solomon Systech SSD2092 I2C touchscreen controller
+
+maintainers:
+  - Gemini PDA Linux Project
+
+description: |
+  Capacitive touchscreen controller found on the Planet Gemini PDA
+  (AUO 5.99" 1080x2160 panel). The interrupt line is polled via GPIO
+  on platforms whose pinctrl lacks EINT support.
+
+allOf:
+  - $ref: touchscreen.yaml#
+
+properties:
+  compatible:
+    const: solomon,ssd2092-touch
+
+  reg:
+    const: 0x53
+
+  reset-gpios:
+    maxItems: 1
+    description: Active-low CTP_RST line
+
+  irq-gpios:
+    maxItems: 1
+    description: Active-low data-ready/INT line, polled by the driver
+
+required:
+  - compatible
+  - reg
+  - reset-gpios
+  - irq-gpios
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+        touchscreen@53 {
+            compatible = "solomon,ssd2092-touch";
+            reg = <0x53>;
+            reset-gpios = <&pio 68 GPIO_ACTIVE_LOW>;
+            irq-gpios = <&pio 85 GPIO_ACTIVE_LOW>;
+            touchscreen-size-x = <1080>;
+            touchscreen-size-y = <2160>;
+            touchscreen-inverted-x;
+            touchscreen-swapped-x-y;
+        };
+    };
