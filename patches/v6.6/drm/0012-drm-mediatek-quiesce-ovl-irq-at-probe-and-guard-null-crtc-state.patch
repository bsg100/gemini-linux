diff --git a/drivers/gpu/drm/mediatek/mtk_disp_ovl.c b/drivers/gpu/drm/mediatek/mtk_disp_ovl.c
index 2bffe4245..c02867f79 100644
--- a/drivers/gpu/drm/mediatek/mtk_disp_ovl.c
+++ b/drivers/gpu/drm/mediatek/mtk_disp_ovl.c
@@ -543,6 +543,24 @@ static int mtk_disp_ovl_probe(struct platform_device *pdev)
 	priv->data = of_device_get_match_data(dev);
 	platform_set_drvdata(pdev, priv);
 
+	/*
+	 * The bootloader may leave the OVL running with its frame-done
+	 * interrupt enabled to display a boot splash. Quiesce the interrupt
+	 * enable and status registers before requesting the IRQ, otherwise a
+	 * leftover interrupt fires as soon as the IRQ is requested — during
+	 * component bind, before the CRTC has an atomic state — and the
+	 * vblank callback dereferences a NULL crtc state.
+	 */
+	ret = clk_prepare_enable(priv->clk);
+	if (ret < 0) {
+		dev_err(dev, "failed to enable ovl clk to quiesce irq: %d\n",
+			ret);
+		return ret;
+	}
+	writel(0x0, priv->regs + DISP_REG_OVL_INTEN);
+	writel(0x0, priv->regs + DISP_REG_OVL_INTSTA);
+	clk_disable_unprepare(priv->clk);
+
 	ret = devm_request_irq(dev, irq, mtk_disp_ovl_irq_handler,
 			       IRQF_TRIGGER_NONE, dev_name(dev), priv);
 	if (ret < 0) {
diff --git a/drivers/gpu/drm/mediatek/mtk_drm_crtc.c b/drivers/gpu/drm/mediatek/mtk_drm_crtc.c
index b6fa4ad2f..43ce1871e 100644
--- a/drivers/gpu/drm/mediatek/mtk_drm_crtc.c
+++ b/drivers/gpu/drm/mediatek/mtk_drm_crtc.c
@@ -616,6 +616,15 @@ static void mtk_crtc_ddp_irq(void *data)
 	struct mtk_drm_crtc *mtk_crtc = to_mtk_crtc(crtc);
 	struct mtk_drm_private *priv = crtc->dev->dev_private;
 
+	/*
+	 * A spurious interrupt (e.g. left over from the bootloader's splash
+	 * screen) can arrive after the vblank callback is registered at bind
+	 * time but before the CRTC has an atomic state. Nothing is pending
+	 * then, so just ignore it.
+	 */
+	if (!crtc->state)
+		return;
+
 #if IS_REACHABLE(CONFIG_MTK_CMDQ)
 	if (!priv->data->shadow_register && !mtk_crtc->cmdq_client.chan)
 		mtk_crtc_ddp_config(crtc, NULL);
