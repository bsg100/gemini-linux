diff --git a/drivers/soc/mediatek/gemini-ddp-dump.c b/drivers/soc/mediatek/gemini-ddp-dump.c
index 941155fcf..45cb60868 100644
--- a/drivers/soc/mediatek/gemini-ddp-dump.c
+++ b/drivers/soc/mediatek/gemini-ddp-dump.c
@@ -23,6 +23,7 @@
  * passes 2/3 at +500 ms to watch upstream counters unfreeze and OVL0
  * FME_CPL latch.
  */
+#include <linux/debugfs.h>
 #include <linux/init.h>
 #include <linux/io.h>
 #include <linux/kernel.h>
@@ -119,10 +120,33 @@ static void gemini_ddp_dump_work_fn(struct work_struct *work)
 				      msecs_to_jiffies(500));
 }
 
+/*
+ * GEMINI-DEBUG: on-demand redump for the "boots with pixels, fades on its
+ * own" hunt (2026-07-10). The 3-pass boot-time schedule above only covers
+ * the first ~9s; the fade happens later and non-deterministically. This
+ * lets us watch OD0_CFG (and everything else) at the moment of a fade
+ * without rebooting: `echo 1 > /sys/kernel/debug/gemini_ddp_dump_now`.
+ */
+static ssize_t gemini_ddp_dump_now_write(struct file *file,
+					  const char __user *buf,
+					  size_t count, loff_t *ppos)
+{
+	gemini_ddp_dump(100 + gemini_dump_pass++);
+	return count;
+}
+
+static const struct file_operations gemini_ddp_dump_now_fops = {
+	.owner = THIS_MODULE,
+	.write = gemini_ddp_dump_now_write,
+	.open  = simple_open,
+};
+
 static int __init gemini_ddp_dump_init(void)
 {
 	schedule_delayed_work(&gemini_ddp_dump_work,
 			      msecs_to_jiffies(8000));
+	debugfs_create_file("gemini_ddp_dump_now", 0200, NULL, NULL,
+			     &gemini_ddp_dump_now_fops);
 	return 0;
 }
 late_initcall(gemini_ddp_dump_init);
