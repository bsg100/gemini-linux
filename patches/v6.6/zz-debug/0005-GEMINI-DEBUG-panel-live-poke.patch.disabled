diff --git a/drivers/gpu/drm/panel/panel-solomon-ssd2092.c b/drivers/gpu/drm/panel/panel-solomon-ssd2092.c
index 96546256a..8c1447b6b 100644
--- a/drivers/gpu/drm/panel/panel-solomon-ssd2092.c
+++ b/drivers/gpu/drm/panel/panel-solomon-ssd2092.c
@@ -27,6 +27,7 @@
  */
 
 #include <linux/backlight.h>
+#include <linux/debugfs.h>
 #include <linux/delay.h>
 #include <linux/gpio/consumer.h>
 #include <linux/module.h>
@@ -297,6 +298,34 @@ static void ssd2092_read_state(struct ssd2092 *priv, const char *when)
 	}
 }
 
+static ssize_t ssd2092_poke_write(struct file *file, const char __user *buf,
+				   size_t count, loff_t *ppos)
+{
+	struct ssd2092 *priv = file->private_data;
+	struct mipi_dsi_device *dsi = priv->dsi;
+	int ret;
+
+	ssd2092_read_state(priv, "live-poke (before re-nudge)");
+
+	ret = mipi_dsi_dcs_write_buffer(dsi, (const u8[]){ 0x11 }, 1);
+	dev_info(&dsi->dev, "GEMINI-PANEL live-poke: sleep-out (0x11) ret=%d\n", ret);
+	msleep(120);
+
+	ret = mipi_dsi_dcs_write_buffer(dsi, (const u8[]){ 0x29 }, 1);
+	dev_info(&dsi->dev, "GEMINI-PANEL live-poke: display-on (0x29) ret=%d\n", ret);
+	msleep(50);
+
+	ssd2092_read_state(priv, "live-poke (after re-nudge)");
+
+	return count;
+}
+
+static const struct file_operations ssd2092_poke_fops = {
+	.owner = THIS_MODULE,
+	.write = ssd2092_poke_write,
+	.open  = simple_open,
+};
+
 static int ssd2092_prepare(struct drm_panel *panel)
 {
 	struct ssd2092 *priv = panel_to_ssd2092(panel);
@@ -520,6 +549,20 @@ static int ssd2092_probe(struct mipi_dsi_device *dsi)
 	}
 
 	dev_info(dev, "Solomon SSD2092 FHD DSI panel registered\n");
+
+	/*
+	 * GEMINI-DEBUG: live poke for the "boots with pixels, fades to
+	 * black on its own" hunt (2026-07-10). Every Linux-side signal
+	 * (PWM duty, DRM plane/crtc state, fb0 writes, reset GPIO) reports
+	 * healthy while the glass is dark, so the only way to see what the
+	 * panel itself thinks is happening is a live DCS re-read while it's
+	 * dark: `echo 1 > /sys/kernel/debug/gemini_panel_poke` re-reads the
+	 * status registers, then re-sends sleep-out(0x11)+display-on(0x29)
+	 * and re-reads again, all via dev_info (visible in dmesg/serial).
+	 */
+	debugfs_create_file("gemini_panel_poke", 0200, NULL, priv,
+			     &ssd2092_poke_fops);
+
 	return 0;
 }
 
