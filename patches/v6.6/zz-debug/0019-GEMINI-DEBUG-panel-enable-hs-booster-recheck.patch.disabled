diff --git a/drivers/gpu/drm/panel/panel-solomon-ssd2092.c b/drivers/gpu/drm/panel/panel-solomon-ssd2092.c
--- a/drivers/gpu/drm/panel/panel-solomon-ssd2092.c
+++ b/drivers/gpu/drm/panel/panel-solomon-ssd2092.c
@@ -499,6 +499,41 @@
 	if (priv->backlight)
 		backlight_enable(priv->backlight);
 
+	/*
+	 * GEMINI-DEBUG (2026-07-11, booster-off hunt): panel enable() runs
+	 * after mtk_dsi's bridge enable, i.e. with the HS clock lane
+	 * running -- unlike the init table, which prepare() sends while the
+	 * link is still LP-only.  If the SSD2092's booster clock derives
+	 * from the DSI clock lane, sleep-out only starts it when HS clock
+	 * is present.  Re-read RDDPM here, re-send sleep-out + display-on
+	 * with HS up, and read again.
+	 */
+	{
+		struct mipi_dsi_device *dsi = priv->dsi;
+		u8 val = 0;
+		int ret;
+
+		ret = mipi_dsi_dcs_read(dsi, 0x0a, &val, 1);
+		dev_info(&dsi->dev,
+			 "GEMINI-PANEL enable(HS up): RDDPM pre  ret=%d val=0x%02x\n",
+			 ret, val);
+
+		ret = mipi_dsi_dcs_write_buffer(dsi, (const u8[]){ 0x11 }, 1);
+		dev_info(&dsi->dev,
+			 "GEMINI-PANEL enable(HS up): sleep-out ret=%d\n", ret);
+		msleep(120);
+		ret = mipi_dsi_dcs_write_buffer(dsi, (const u8[]){ 0x29 }, 1);
+		dev_info(&dsi->dev,
+			 "GEMINI-PANEL enable(HS up): display-on ret=%d\n", ret);
+		msleep(50);
+
+		val = 0;
+		ret = mipi_dsi_dcs_read(dsi, 0x0a, &val, 1);
+		dev_info(&dsi->dev,
+			 "GEMINI-PANEL enable(HS up): RDDPM post ret=%d val=0x%02x\n",
+			 ret, val);
+	}
+
 	priv->enabled = true;
 	return 0;
 }
