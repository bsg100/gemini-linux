--- /dev/null
+++ b/drivers/gpu/drm/panel/panel-renesas-r63419.c
@@ -0,0 +1,435 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Renesas R63419 WQHD DSI panel driver
+ *
+ * Panel: "Truly Phantom" 5.99" 1440×2560 MIPI DSI CMD mode
+ * Used on: Planet Computers Gemini PDA (MT6797X / Helio X27)
+ *
+ * This panel uses DUAL DSI (port 0 + port 1, each 4-lane 423 MHz).
+ * The mainline MT6797 DRM driver does not yet support dual DSI —
+ * single-port operation at reduced bandwidth is used for bring-up.
+ * TODO: enable dual-DSI once MT6797 MMSYS driver supports it.
+ *
+ * LCD bias: TPS65132 dual-output ±5 V (AVDD/AVEE), I2C bus 1, addr 0x3E.
+ * In DT, supply regulators vreg-avdd and vreg-avee are expected.
+ *
+ * Init sequence extracted from:
+ *   drivers/misc/mediatek/lcm/mediatek/
+ *     r63419_wqhd_truly_phantom_2k_cmd_ok_mt6797/
+ *     r63419_wqhd_truly_phantom_2k_cmd_ok_mt6797.c
+ *   (MediaTek 3.18 BSP kernel, Gemini PDA)
+ */
+
+#include <linux/backlight.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/regulator/consumer.h>
+
+#include <video/mipi_display.h>
+
+#include <drm/drm_crtc.h>
+#include <drm/drm_mipi_dsi.h>
+#include <drm/drm_modes.h>
+#include <drm/drm_panel.h>
+
+struct r63419 {
+	struct drm_panel panel;
+	struct mipi_dsi_device *dsi;
+
+	struct regulator *avdd;
+	struct regulator *avee;
+	struct gpio_desc *reset_gpio;
+	struct backlight_device *backlight;
+
+	bool prepared;
+	bool enabled;
+};
+
+static inline struct r63419 *panel_to_r63419(struct drm_panel *panel)
+{
+	return container_of(panel, struct r63419, panel);
+}
+
+#define dsi_dcs_write_seq(dsi, seq...)					\
+({									\
+	static const u8 d[] = { seq };					\
+	int ret;							\
+	ret = mipi_dsi_dcs_write_buffer(dsi, d, ARRAY_SIZE(d));		\
+	if (ret < 0) {							\
+		dev_err(&(dsi)->dev,					\
+			"DSI write (cmd 0x%02x) failed: %d\n", d[0], ret); \
+		return ret;						\
+	}								\
+})
+
+static int r63419_init_sequence(struct r63419 *priv)
+{
+	struct mipi_dsi_device *dsi = priv->dsi;
+
+	/* LCD panel position and display direction */
+	dsi_dcs_write_seq(dsi, 0x36, 0x40);
+
+	/* Manufacturer command access protect — unlock */
+	dsi_dcs_write_seq(dsi, 0xB0, 0x00);
+
+	dsi_dcs_write_seq(dsi, 0xD6, 0x01);
+
+	/* Interface setting: Command mode */
+	dsi_dcs_write_seq(dsi, 0xB3, 0x04, 0x00, 0x00);
+
+	/* Display mode: internal oscillator */
+	dsi_dcs_write_seq(dsi, 0xB4, 0x00);
+
+	/* DSI control: 740–1000 Mbps HS clock range */
+	dsi_dcs_write_seq(dsi, 0xB6, 0x3A, 0xD3);
+
+	/* DSI virtual channel for port A */
+	dsi_dcs_write_seq(dsi, 0xBE, 0x04);
+
+	/* VSOUT / HSOUT disable */
+	dsi_dcs_write_seq(dsi, 0xC3, 0x00, 0x00, 0x00);
+
+	dsi_dcs_write_seq(dsi, 0xC5, 0x00);
+
+	/* SOUT slew rate */
+	dsi_dcs_write_seq(dsi, 0xC0, 0x00, 0x00, 0x00, 0x00);
+
+	/* Display setting 1 */
+	dsi_dcs_write_seq(dsi, 0xC1,
+			  0x00, 0x61, 0x00, 0x20, 0x8C, 0xA4, 0x16, 0xFB,
+			  0xBF, 0x98, 0x83, 0x9A, 0x7B, 0xCF, 0x35, 0x74,
+			  0x4C, 0xF9, 0x9F, 0x2D, 0x95, 0x88, 0x00, 0x00,
+			  0x00, 0x00, 0x00, 0x00, 0x02, 0x63, 0x23, 0x03,
+			  0x00, 0xFF, 0x11);
+
+	/* Display setting 2: VBP=10, VFP=10, HBP=8, HFP=8 */
+	dsi_dcs_write_seq(dsi, 0xC2, 0x0A, 0x0A, 0x00, 0x08, 0x08, 0xF0, 0x00, 0x04);
+
+	/* Source timing */
+	dsi_dcs_write_seq(dsi, 0xC4,
+			  0x70, 0x00, 0x00, 0x33, 0x33, 0x33, 0x33, 0x33,
+			  0x33, 0x33, 0x33, 0x01, 0x05, 0x01);
+
+	/* LTPS timing */
+	dsi_dcs_write_seq(dsi, 0xC6,
+			  0x5A, 0x29, 0x29, 0x01, 0x01, 0x00, 0x02, 0x00,
+			  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+			  0x00, 0x06, 0x15, 0x08, 0x5A);
+
+	/* Panel pin control */
+	dsi_dcs_write_seq(dsi, 0xCB,
+			  0x7F, 0xE0, 0x07, 0xFF, 0x00, 0x00, 0x00, 0x00,
+			  0x54, 0xE0, 0x07, 0x2A, 0xC8, 0x00, 0x00);
+
+	/* Panel interface control */
+	dsi_dcs_write_seq(dsi, 0xCC, 0x11);
+
+	/* Sequencer timing control */
+	dsi_dcs_write_seq(dsi, 0xD7,
+			  0x82, 0xFF, 0x21, 0x8E, 0x8C, 0xF1, 0x87, 0x3F,
+			  0x7E, 0x10, 0x00, 0x00, 0x8F);
+
+	/* Sequencer control */
+	dsi_dcs_write_seq(dsi, 0xD9, 0x00, 0x00);
+
+	/* Power setting: charge pump */
+	dsi_dcs_write_seq(dsi, 0xD0, 0x11, 0x17, 0x17, 0xFD);
+
+	/* Power setting: internal power — +4V / −4V */
+	dsi_dcs_write_seq(dsi, 0xD2,
+			  0xCD, 0x2B, 0x2B, 0x33, 0x12, 0x33, 0x33, 0x33,
+			  0x77, 0x77, 0x33, 0x33, 0x33, 0x00, 0x00, 0x00);
+
+	/* VCOM setting */
+	dsi_dcs_write_seq(dsi, 0xD5, 0x06, 0x00, 0x00, 0x01, 0x1E, 0x01, 0x1E);
+
+	/* Gamma — RGB separated, positive + negative */
+	dsi_dcs_write_seq(dsi, 0xC7,
+			  0x00, 0x0C, 0x14, 0x1D, 0x2C, 0x3A, 0x44, 0x54,
+			  0x38, 0x40, 0x4C, 0x59, 0x63, 0x6B, 0x7F,
+			  0x00, 0x0C, 0x14, 0x1D, 0x2C, 0x3A, 0x44, 0x54,
+			  0x38, 0x40, 0x4C, 0x59, 0x63, 0x6B, 0x7F);
+
+	/* Gamma correction table */
+	dsi_dcs_write_seq(dsi, 0xC8,
+			  0x01, 0x00, 0x00, 0x00, 0x00, 0xFC, 0xEF, 0x00,
+			  0x00, 0x00, 0x00, 0xFC, 0xEF, 0x00, 0x00, 0x00,
+			  0x00, 0xFC, 0x0F);
+
+	/* Backlight control — low, medium, high brightness settings */
+	dsi_dcs_write_seq(dsi, 0xB8, 0x57, 0x3D, 0x19, 0x1E, 0x0A, 0x50, 0x50);
+	dsi_dcs_write_seq(dsi, 0xB9, 0x6F, 0x3D, 0x28, 0x3C, 0x14, 0xC8, 0xC8);
+	dsi_dcs_write_seq(dsi, 0xBA, 0xB5, 0x33, 0x41, 0x64, 0x23, 0xA0, 0xA0);
+
+	/* Content Adaptive Backlight Control (CABC) */
+	dsi_dcs_write_seq(dsi, 0xCE,
+			  0x55, 0x40, 0x49, 0x53, 0x59, 0x5E, 0x63, 0x68,
+			  0x6E, 0x74, 0x7E, 0x8A, 0x98, 0xA8, 0xBB, 0xD0,
+			  0xFF, 0x04, 0x00, 0x04, 0x04, 0x00, 0x00, 0x69, 0x5A);
+
+	/* Manufacturer command access protect — lock */
+	dsi_dcs_write_seq(dsi, 0xB0, 0x03);
+
+	/* Tearing effect line ON (TE on vsync) */
+	dsi_dcs_write_seq(dsi, 0x35, 0x00);
+
+	/* Write control display: backlight on, dimming on */
+	dsi_dcs_write_seq(dsi, 0x53, 0x2C);
+
+	return 0;
+}
+
+static int r63419_prepare(struct drm_panel *panel)
+{
+	struct r63419 *priv = panel_to_r63419(panel);
+	int ret;
+
+	if (priv->prepared)
+		return 0;
+
+	ret = regulator_enable(priv->avdd);
+	if (ret < 0) {
+		dev_err(panel->dev, "failed to enable avdd: %d\n", ret);
+		return ret;
+	}
+
+	ret = regulator_enable(priv->avee);
+	if (ret < 0) {
+		dev_err(panel->dev, "failed to enable avee: %d\n", ret);
+		goto disable_avdd;
+	}
+
+	msleep(5);
+
+	/* Reset pulse */
+	gpiod_set_value_cansleep(priv->reset_gpio, 1);
+	msleep(1);
+	gpiod_set_value_cansleep(priv->reset_gpio, 0);
+	msleep(10);
+	gpiod_set_value_cansleep(priv->reset_gpio, 1);
+	msleep(10);
+
+	dev_dbg(panel->dev, "sending init sequence\n");
+	ret = r63419_init_sequence(priv);
+	if (ret < 0) {
+		dev_err(panel->dev, "init sequence failed: %d\n", ret);
+		goto disable_avee;
+	}
+
+	priv->prepared = true;
+	return 0;
+
+disable_avee:
+	/* Leave reset asserted (low) so a retry starts from a known state. */
+	gpiod_set_value_cansleep(priv->reset_gpio, 0);
+	regulator_disable(priv->avee);
+disable_avdd:
+	regulator_disable(priv->avdd);
+	return ret;
+}
+
+static int r63419_enable(struct drm_panel *panel)
+{
+	struct r63419 *priv = panel_to_r63419(panel);
+	struct mipi_dsi_device *dsi = priv->dsi;
+	int ret;
+
+	if (priv->enabled)
+		return 0;
+
+	/* Sleep out first, then turn the display on (datasheet order). */
+	ret = mipi_dsi_dcs_exit_sleep_mode(dsi);
+	if (ret < 0) {
+		dev_err(&dsi->dev, "exit_sleep_mode failed: %d\n", ret);
+		return ret;
+	}
+	msleep(120);
+
+	ret = mipi_dsi_dcs_set_display_on(dsi);
+	if (ret < 0) {
+		dev_err(&dsi->dev, "set_display_on failed: %d\n", ret);
+		return ret;
+	}
+	msleep(20);
+
+	if (priv->backlight)
+		backlight_enable(priv->backlight);
+
+	priv->enabled = true;
+	return 0;
+}
+
+static int r63419_disable(struct drm_panel *panel)
+{
+	struct r63419 *priv = panel_to_r63419(panel);
+	struct mipi_dsi_device *dsi = priv->dsi;
+
+	if (!priv->enabled)
+		return 0;
+
+	if (priv->backlight)
+		backlight_disable(priv->backlight);
+
+	mipi_dsi_dcs_set_display_off(dsi);
+	msleep(20);
+	mipi_dsi_dcs_enter_sleep_mode(dsi);
+	msleep(120);
+
+	priv->enabled = false;
+	return 0;
+}
+
+static int r63419_unprepare(struct drm_panel *panel)
+{
+	struct r63419 *priv = panel_to_r63419(panel);
+
+	if (!priv->prepared)
+		return 0;
+
+	gpiod_set_value_cansleep(priv->reset_gpio, 0);
+	msleep(10);
+
+	regulator_disable(priv->avee);
+	regulator_disable(priv->avdd);
+
+	priv->prepared = false;
+	return 0;
+}
+
+/*
+ * Display timing.
+ *
+ * Mode: CMD (video timing provided for DRM mode-setting only).
+ * PLL: 423 MHz (single DSI; dual-DSI would use same clock per port).
+ * Physical size: 74.5 mm × 132.5 mm (from vendor LCM params).
+ *
+ * Horizontal: pixel_clock = (HSA+HBP+WIDTH+HFP) × VLINES × FPS
+ * Vertical timing from vendor: VSA=4 VBP=4 VFP=8
+ * FPS target: ~60 Hz
+ *
+ * TODO (verify on hardware): .clock=154980 kHz does not match
+ * htotal*vtotal*60 for 1440x2560, and the HFP/HBP values here disagree with
+ * the 0xC2 init-sequence porch comment. Reconcile against the vendor LCM
+ * params before relying on video timing. CMD mode tolerates this for bring-up.
+ */
+static const struct drm_display_mode r63419_mode = {
+	.clock		= 154980,	/* kHz — approx 60 Hz */
+	.hdisplay	= 1440,
+	.hsync_start	= 1440 + 150,	/* HFP=150 */
+	.hsync_end	= 1440 + 150 + 8,	/* HSA=8 */
+	.htotal		= 1440 + 150 + 8 + 60,	/* HBP=60 */
+	.vdisplay	= 2560,
+	.vsync_start	= 2560 + 8,	/* VFP=8 */
+	.vsync_end	= 2560 + 8 + 4,	/* VSA=4 */
+	.vtotal		= 2560 + 8 + 4 + 4,	/* VBP=4 */
+	.width_mm	= 74,
+	.height_mm	= 132,
+};
+
+static int r63419_get_modes(struct drm_panel *panel,
+			    struct drm_connector *connector)
+{
+	struct drm_display_mode *mode;
+
+	mode = drm_mode_duplicate(connector->dev, &r63419_mode);
+	if (!mode)
+		return -ENOMEM;
+
+	drm_mode_set_name(mode);
+	mode->type = DRM_MODE_TYPE_DRIVER | DRM_MODE_TYPE_PREFERRED;
+	drm_mode_probed_add(connector, mode);
+
+	connector->display_info.width_mm = r63419_mode.width_mm;
+	connector->display_info.height_mm = r63419_mode.height_mm;
+
+	return 1;
+}
+
+static const struct drm_panel_funcs r63419_panel_funcs = {
+	.prepare	= r63419_prepare,
+	.enable		= r63419_enable,
+	.disable	= r63419_disable,
+	.unprepare	= r63419_unprepare,
+	.get_modes	= r63419_get_modes,
+};
+
+static int r63419_probe(struct mipi_dsi_device *dsi)
+{
+	struct device *dev = &dsi->dev;
+	struct r63419 *priv;
+	int ret;
+
+	priv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+
+	priv->dsi = dsi;
+	mipi_dsi_set_drvdata(dsi, priv);
+
+	dev_dbg(dev, "probing Renesas R63419 panel\n");
+
+	priv->avdd = devm_regulator_get(dev, "avdd");
+	if (IS_ERR(priv->avdd))
+		return dev_err_probe(dev, PTR_ERR(priv->avdd), "avdd regulator\n");
+
+	priv->avee = devm_regulator_get(dev, "avee");
+	if (IS_ERR(priv->avee))
+		return dev_err_probe(dev, PTR_ERR(priv->avee), "avee regulator\n");
+
+	priv->reset_gpio = devm_gpiod_get(dev, "reset", GPIOD_OUT_LOW);
+	if (IS_ERR(priv->reset_gpio))
+		return dev_err_probe(dev, PTR_ERR(priv->reset_gpio), "reset gpio\n");
+
+	priv->backlight = devm_of_find_backlight(dev);
+	if (IS_ERR(priv->backlight))
+		return dev_err_probe(dev, PTR_ERR(priv->backlight), "backlight\n");
+
+	drm_panel_init(&priv->panel, dev, &r63419_panel_funcs,
+		       DRM_MODE_CONNECTOR_DSI);
+
+	drm_panel_add(&priv->panel);
+
+	dsi->lanes = 4;
+	dsi->format = MIPI_DSI_FMT_RGB888;
+	dsi->mode_flags = MIPI_DSI_MODE_LPM | MIPI_DSI_CLOCK_NON_CONTINUOUS;
+
+	ret = mipi_dsi_attach(dsi);
+	if (ret < 0) {
+		dev_err(dev, "failed to attach DSI: %d\n", ret);
+		drm_panel_remove(&priv->panel);
+		return ret;
+	}
+
+	dev_info(dev, "Renesas R63419 WQHD DSI panel registered\n");
+	return 0;
+}
+
+static void r63419_remove(struct mipi_dsi_device *dsi)
+{
+	struct r63419 *priv = mipi_dsi_get_drvdata(dsi);
+
+	mipi_dsi_detach(dsi);
+	drm_panel_remove(&priv->panel);
+}
+
+static const struct of_device_id r63419_of_match[] = {
+	{ .compatible = "renesas,r63419-truly-wqhd" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, r63419_of_match);
+
+static struct mipi_dsi_driver r63419_driver = {
+	.probe  = r63419_probe,
+	.remove = r63419_remove,
+	.driver = {
+		.name = "panel-renesas-r63419",
+		.of_match_table = r63419_of_match,
+	},
+};
+module_mipi_dsi_driver(r63419_driver);
+
+MODULE_AUTHOR("Ben Hamilton <ben@wakatipu.co>");
+MODULE_DESCRIPTION("Renesas R63419 WQHD DSI panel (Gemini PDA)");
+MODULE_LICENSE("GPL");
