diff --git a/drivers/regulator/fan53555.c b/drivers/regulator/fan53555.c
index 48f312167..2f4fa2d33 100644
--- a/drivers/regulator/fan53555.c
+++ b/drivers/regulator/fan53555.c
@@ -34,6 +34,13 @@
 #define TCS4525_TIME		0x13
 #define TCS4525_COMMAND		0x14
 
+/* RT5735 register layout — shares addresses with TCS4525 */
+#define RT5735_VSEL0		0x11	/* PROGVSEL0 — active voltage */
+#define RT5735_VSEL1		0x10	/* PROGVSEL1 — standby voltage */
+#define RT5735_TIME		0x13	/* DVS-up slew rate in bits [4:2] */
+#define RT5735_COMMAND		0x14	/* PWM mode select in bit [7] */
+#define RT5735_PID		0x03	/* Product ID */
+
 /* Control register */
 #define FAN53555_CONTROL	0x02
 /* IC Type */
@@ -65,6 +72,11 @@
 
 #define TCS_SLEW_MASK		GENMASK(4, 3)
 
+/* RT5735 bit definitions */
+#define RT5735_VSEL_MODE	BIT(7)		/* forced PWM in COMMAND[7] */
+#define RT5735_SLEW_MASK	GENMASK(4, 2)	/* DVS-up rate in TIME[4:2] */
+#define RT5735_NVOLTAGES	128
+
 enum fan53555_vendor {
 	FAN53526_VENDOR_FAIRCHILD = 0,
 	FAN53555_VENDOR_FAIRCHILD,
@@ -72,6 +84,7 @@ enum fan53555_vendor {
 	RK8602_VENDOR_ROCKCHIP,		/* RK8602, RK8603 */
 	FAN53555_VENDOR_SILERGY,
 	FAN53526_VENDOR_TCS,
+	FAN53555_VENDOR_RICHTEK,	/* RT5735 */
 };
 
 enum {
@@ -238,6 +251,22 @@ static const unsigned int tcs_slew_rates[] = {
 	 2300,
 };
 
+/*
+ * RT5735 DVS-up slew rates for TIME[4:2].
+ * Index matches the 3-bit field value; rates in µV/µs.
+ * Source: Richtek RT5735 vendor driver (rt5735.h).
+ */
+static const unsigned int rt5735_slew_rates[] = {
+	64000,	/* 0 */
+	16000,	/* 1 */
+	32000,	/* 2 */
+	 8000,	/* 3 */
+	 4000,	/* 4 */
+	 4000,	/* 5 */
+	32000,	/* 6 — Gemini PDA default (dvs_up = 6) */
+	 8000,	/* 7 */
+};
+
 static const struct regulator_ops fan53555_regulator_ops = {
 	.set_voltage_sel = regulator_set_voltage_sel_regmap,
 	.get_voltage_sel = regulator_get_voltage_sel_regmap,
@@ -423,6 +452,19 @@ static int fan53526_voltages_setup_tcs(struct fan53555_device_info *di)
 	return 0;
 }
 
+static int fan53555_voltages_setup_richtek(struct fan53555_device_info *di)
+{
+	/* VOUT = 600mV + NSELx * 6.25mV, range 600mV to 1393.75mV */
+	di->vsel_min = 600000;
+	di->vsel_step = 6250;
+	di->vsel_count = RT5735_NVOLTAGES;
+	di->slew_reg = RT5735_TIME;
+	di->slew_mask = RT5735_SLEW_MASK;
+	di->ramp_delay_table = rt5735_slew_rates;
+	di->n_ramp_values = ARRAY_SIZE(rt5735_slew_rates);
+	return 0;
+}
+
 /* For 00,01,03,05 options:
  * VOUT = 0.60V + NSELx * 10mV, from 0.60 to 1.23V.
  * For 04 option:
@@ -491,6 +533,13 @@ static int fan53555_device_setup(struct fan53555_device_info *di,
 		di->sleep_en_reg = di->sleep_reg;
 		di->en_reg = di->vol_reg;
 		break;
+	case FAN53555_VENDOR_RICHTEK:
+		/* PROGVSEL0 (0x11) = active, PROGVSEL1 (0x10) = standby */
+		di->sleep_reg = RT5735_VSEL1;
+		di->vol_reg = RT5735_VSEL0;
+		di->sleep_en_reg = di->sleep_reg;
+		di->en_reg = di->vol_reg;
+		break;
 	default:
 		dev_err(di->dev, "vendor %d not supported!\n", di->vendor);
 		return -EINVAL;
@@ -540,6 +589,11 @@ static int fan53555_device_setup(struct fan53555_device_info *di,
 			break;
 		}
 		break;
+	case FAN53555_VENDOR_RICHTEK:
+		/* Forced PWM mode is bit 7 of COMMAND (0x14) */
+		di->mode_reg = RT5735_COMMAND;
+		di->mode_mask = RT5735_VSEL_MODE;
+		break;
 	default:
 		dev_err(di->dev, "vendor %d not supported!\n", di->vendor);
 		return -EINVAL;
@@ -565,6 +619,9 @@ static int fan53555_device_setup(struct fan53555_device_info *di,
 	case FAN53526_VENDOR_TCS:
 		ret = fan53526_voltages_setup_tcs(di);
 		break;
+	case FAN53555_VENDOR_RICHTEK:
+		ret = fan53555_voltages_setup_richtek(di);
+		break;
 	default:
 		dev_err(di->dev, "vendor %d not supported!\n", di->vendor);
 		return -EINVAL;
@@ -652,6 +709,9 @@ static const struct of_device_id __maybe_unused fan53555_dt_ids[] = {
 	}, {
 		.compatible = "tcs,tcs4526",
 		.data = (void *)FAN53526_VENDOR_TCS
+	}, {
+		.compatible = "richtek,rt5735",
+		.data = (void *)FAN53555_VENDOR_RICHTEK
 	},
 	{ }
 };
@@ -764,6 +824,9 @@ static const struct i2c_device_id fan53555_id[] = {
 	}, {
 		.name = "tcs4526",
 		.driver_data = FAN53526_VENDOR_TCS
+	}, {
+		.name = "rt5735",
+		.driver_data = FAN53555_VENDOR_RICHTEK
 	},
 	{ },
 };
