+	[DDP_COMPONENT_WDMA1] = MT6797_MUTEX_MOD_DISP_WDMA1,
+};
+
 static const unsigned int mt8173_mutex_mod[DDP_COMPONENT_ID_MAX] = {
 	[DDP_COMPONENT_AAL0] = MT8173_MUTEX_MOD_DISP_AAL,
 	[DDP_COMPONENT_COLOR0] = MT8173_MUTEX_MOD_DISP_COLOR0,
@@ -571,6 +609,19 @@ static const unsigned int mt6795_mutex_sof[DDP_MUTEX_SOF_MAX] = {
 	[MUTEX_SOF_DPI0] = MUTEX_SOF_DPI0,
 };
 
+/*
+ * MT6797 needs the EOF field (bits 6-8) set as well as SOF, or the overlay
+ * hardware never receives its frame-done interrupt: the vendor 3.18
+ * ddp_get_mutex_src() sets SOF and EOF to DSI0 for a video-mode DSI path
+ * (SOF_VAL_MUTEX0_EOF_FROM_DSI0 == 1, at REG_FLD(3, 6)).
+ */
+static const unsigned int mt6797_mutex_sof[DDP_MUTEX_SOF_MAX] = {
+	[MUTEX_SOF_SINGLE_MODE] = MUTEX_SOF_SINGLE_MODE,
+	[MUTEX_SOF_DSI0] = MUTEX_SOF_DSI0 | (MUTEX_SOF_DSI0 << 6),
+	[MUTEX_SOF_DSI1] = MUTEX_SOF_DSI1 | (MUTEX_SOF_DSI1 << 6),
+	[MUTEX_SOF_DPI0] = MUTEX_SOF_DPI0 | (MUTEX_SOF_DPI0 << 6),
+};
+
 static const unsigned int mt8167_mutex_sof[DDP_MUTEX_SOF_MAX] = {
 	[MUTEX_SOF_SINGLE_MODE] = MUTEX_SOF_SINGLE_MODE,
 	[MUTEX_SOF_DSI0] = MUTEX_SOF_DSI0,
@@ -648,6 +699,17 @@ static const struct mtk_mutex_data mt8167_mutex_driver_data = {
 	.no_clk = true,
 };
 
+static const struct mtk_mutex_data mt6797_mutex_driver_data = {
+	.mutex_mod = mt6797_mutex_mod,
+	.mutex_sof = mt6797_mutex_sof,
+	.mutex_mod_reg = MT2701_MUTEX0_MOD0,
+	.mutex_sof_reg = MT2701_MUTEX0_SOF0,
+	/* No dedicated mutex clock gate on MT6797: neither the mainline
+	 * MM gate table (clk-mt6797-mm.c) nor the vendor 3.18 ddp_clkmgr
+	 * has one. */
+	.no_clk = true,
+};
+
 static const struct mtk_mutex_data mt8173_mutex_driver_data = {
 	.mutex_mod = mt8173_mutex_mod,
 	.mutex_sof = mt2712_mutex_sof,
@@ -1032,6 +1094,7 @@ static const struct of_device_id mutex_driver_dt_match[] = {
 	{ .compatible = "mediatek,mt2701-disp-mutex", .data = &mt2701_mutex_driver_data },
 	{ .compatible = "mediatek,mt2712-disp-mutex", .data = &mt2712_mutex_driver_data },
 	{ .compatible = "mediatek,mt6795-disp-mutex", .data = &mt6795_mutex_driver_data },
+	{ .compatible = "mediatek,mt6797-disp-mutex", .data = &mt6797_mutex_driver_data },
 	{ .compatible = "mediatek,mt8167-disp-mutex", .data = &mt8167_mutex_driver_data },
 	{ .compatible = "mediatek,mt8173-disp-mutex", .data = &mt8173_mutex_driver_data },
 	{ .compatible = "mediatek,mt8183-disp-mutex", .data = &mt8183_mutex_driver_data },
