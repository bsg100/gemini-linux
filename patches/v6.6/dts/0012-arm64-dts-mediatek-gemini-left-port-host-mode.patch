@@ -446,6 +462,22 @@ touchscreen@5d {
 		status = "disabled";
 	};
 
+	/*
+	 * FUSB301 USB Type-C CC controller — LEFT port (the mtu3/ssusb
+	 * port). Found on i2c1 by the 2026-07-14 vendor harvest and
