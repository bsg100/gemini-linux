+	 * off (the pin gates, it doesn't enable), so charging from a Mac
+	 * is unaffected when the port is idle.
+	 */
+	otg_drvvbus_hog: otg-drvvbus-hog {
+		gpio-hog;
+		gpios = <107 GPIO_ACTIVE_HIGH>;
+		output-high;
+		line-name = "otg-drvvbus";
+	};
