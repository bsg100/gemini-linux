+		 */
+		vbus-supply = <&otg_vbus>;
+		dr_mode = "otg";
+		usb-role-switch;
+		role-switch-default-mode = "host";
 		maximum-speed = "high-speed";
+		#address-cells = <2>;
+		#size-cells = <2>;
