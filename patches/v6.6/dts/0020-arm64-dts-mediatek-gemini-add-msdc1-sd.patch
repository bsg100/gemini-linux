+				mt6351_vmch_reg: vmch {
+					regulator-name = "vmch";
+					regulator-min-microvolt = <3000000>;
+					regulator-max-microvolt = <3000000>;
+				};
+
+				mt6351_vmc_reg: vmc {
+					regulator-name = "vmc";
+					regulator-min-microvolt = <3000000>;
+					regulator-max-microvolt = <3000000>;
+				};
 			};
 		};
 
