diff --git a/arch/arm64/boot/dts/mediatek/mt6797-gemini-pda.dts b/arch/arm64/boot/dts/mediatek/mt6797-gemini-pda.dts
--- a/arch/arm64/boot/dts/mediatek/mt6797-gemini-pda.dts
+++ b/arch/arm64/boot/dts/mediatek/mt6797-gemini-pda.dts
@@ -417,14 +417,27 @@
 	};
 
 	/*
-	 * FUSB301A USB Type-C CC controller at 0x25.
-	 * Deferred: USB2 host mode works without CC detection.
-	 * Enable in Phase 4+ once USB role switch is wired up.
+	 * FUSB301A USB Type-C CC controller at 0x25. Enabled as an I2C-only
+	 * diagnostic (build #149, WiFi Stage 1 G1a investigation): every GPIO
+	 * gate documented in the vendor source (VBUS/94, sw7226/72,
+	 * fusb301a-mux/70+71) is confirmed correctly asserted on hardware and
+	 * a real USB device still never enumerates on the correct (left)
+	 * port. This chip has never actually been talked to over I2C by this
+	 * kernel -- deliberately NOT wired as a usb-role-switch consumer yet
+	 * (no "usb-role-switch = <&ssusb>;" property): the driver's own
+	 * fusb301a_update_role() is flagged FIXME/unverified and may derive
+	 * HOST vs DEVICE backwards from VBUS_OK, which could set
+	 * USB_ROLE_NONE and disable the port entirely -- worse than today's
+	 * static role-switch-default-mode="host". This build only checks
+	 * whether the chip responds/probes at all (dev_info "ready" on
+	 * success, dev_err_probe on failure) -- a basic sanity check that's
+	 * never been done. No interrupts wired: pinctrl-mt6797 has no EINT
+	 * support (B-11), same limitation as the charger node above.
 	 */
 	usb_cc: typec@25 {
 		compatible = "onsemi,fusb301a";
 		reg = <0x25>;
-		status = "disabled";
+		status = "okay";
 	};
 };
 
