+	/*
+	 * SMI LARB0 (Streaming Memory Interface local arbiter for display).
+	 * Address 0x14020000 confirmed from vendor kernel DTB embedded in
+	 * planet/kali_boot.img (node smi_larb0@14020000).
+	 * 0x14010000 is disp_rdma1 — do not use that address here.
+	 */
+	larb0: larb@14020000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x14020000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_MM>;
+		clocks = <&mmsys CLK_MM_SMI_LARB0>,
+			 <&mmsys CLK_MM_SMI_LARB0>;
+		clock-names = "apb", "smi";
+	};
+
+	/*
+	 * SMI common (Streaming Memory Interface shared bus arbiter).
+	 * Address 0x14022000 confirmed from vendor kernel DTB embedded in
+	 * planet/kali_boot.img (node smi_common@14022000).
+	 * 0x14019000 is dsi_ufoe (Unified Frame Output Engine) — do not use
+	 * that address here.
+	 */
+	smi_common: smi@14022000 {
