 	if (timer < 0) {
 		spm_vcorefs_dump_dvfs_regs(NULL);
-		BUG();
+		/* HARVEST: was BUG() -- this SPM/PCM screen-on DVFS handshake
+		 * timeout hard-hung the board (no WDT reset, needed a manual
