diff --git a/kernel-3.18/drivers/misc/mediatek/connectivity/common/common_main/mt6797/mtk_wcn_consys_hw.c b/kernel-3.18/drivers/misc/mediatek/connectivity/common/common_main/mt6797/mtk_wcn_consys_hw.c
index 045fc78d..d0679216 100644
--- a/kernel-3.18/drivers/misc/mediatek/connectivity/common/common_main/mt6797/mtk_wcn_consys_hw.c
+++ b/kernel-3.18/drivers/misc/mediatek/connectivity/common/common_main/mt6797/mtk_wcn_consys_hw.c
@@ -276,6 +276,33 @@ static INT32 mtk_wmt_remove(struct platform_device *pdev)
 	return 0;
 }
 
+static VOID harvest_snap(const PINT8 tag, int mcu_powered)
+{
+	static VOID __iomem *harvest_1f00;
+	UINT32 v1f00 = 0, cpupcr = 0, pwr = 0, ack = 0, acks = 0;
+
+	if (!harvest_1f00)
+		harvest_1f00 = ioremap_nocache(0x10001f00, 0x4);
+	if (harvest_1f00)
+		v1f00 = CONSYS_REG_READ(harvest_1f00);
+	/* HARVEST: conn_reg.mcu_base lives in the CONN_PERIPHERALS DEVAPC
+	 * domain, which only accepts AP-side reads once the consys MTCMOS/
+	 * clock power-on steps below have run. Reading CPUPCR before that
+	 * (the "reg_ctrl-on-entry" snapshot, taken at function entry) trips
+	 * a DEVAPC violation storm and eventually hard-resets the board with
+	 * no panic/WDT text. Skip it when the caller tells us consys isn't
+	 * powered yet. */
+	if (mcu_powered && conn_reg.mcu_base)
+		cpupcr = CONSYS_REG_READ(conn_reg.mcu_base + CONSYS_CPUPCR_OFFSET);
+	if (conn_reg.spm_base) {
+		pwr = CONSYS_REG_READ(conn_reg.spm_base + CONSYS_TOP1_PWR_CTRL_OFFSET);
+		ack = CONSYS_REG_READ(conn_reg.spm_base + CONSYS_PWR_CONN_ACK_OFFSET);
+		acks = CONSYS_REG_READ(conn_reg.spm_base + CONSYS_PWR_CONN_ACK_S_OFFSET);
+	}
+	pr_info("HARVEST-SNAP[%s]: 0x10001f00=0x%08x CPUPCR=0x%08x TOP1_PWR=0x%08x ACK=0x%08x ACK_S=0x%08x\n",
+		tag, v1f00, cpupcr, pwr, ack, acks);
+}
+
 INT32 mtk_wcn_consys_hw_reg_ctrl(UINT32 on, UINT32 co_clock_type)
 {
 	INT32 iRet = -1;
@@ -287,6 +314,7 @@ INT32 mtk_wcn_consys_hw_reg_ctrl(UINT32 on, UINT32 co_clock_type)
 #endif
 
 	WMT_PLAT_DBG_FUNC("CONSYS-HW-REG-CTRL(0x%08x),start\n", on);
+	harvest_snap(on ? "reg_ctrl-on-entry" : "reg_ctrl-off-entry", on ? 0 : 1);
 
 	if (on) {
 		WMT_PLAT_DBG_FUNC("++\n");
@@ -412,6 +440,7 @@ INT32 mtk_wcn_consys_hw_reg_ctrl(UINT32 on, UINT32 co_clock_type)
 		WMT_PLAT_DBG_FUNC("[CCF]enable clk_infra_conn_main\n");
 #endif /* defined(CONFIG_MTK_CLKMGR) */
 #endif
+		harvest_snap("pre-chipid-poll", 1);
 		/*12.poll CONNSYS CHIP ID until chipid is returned  0x18070008 */
 		while (retry-- > 0) {
 			consysHwChipId = CONSYS_REG_READ(conn_reg.mcu_base + CONSYS_CHIP_ID_OFFSET);
@@ -805,6 +834,7 @@ INT32 mtk_wcn_consys_hw_pwr_on(UINT32 co_clock_type)
 		return -1;
 	}
 	iRet += mtk_wcn_consys_hw_reg_ctrl(1, co_clock_type);
+	harvest_snap("after-reg-ctrl-on", 1);
 	iRet += mtk_wcn_consys_hw_gpio_ctrl(1);
 #if CONSYS_ENALBE_SET_JTAG
 	if (gJtagCtrl)
@@ -838,6 +868,7 @@ INT32 mtk_wcn_consys_hw_rst(UINT32 co_clock_type)
 
 	/*2. do whole hw power on flow */
 	iRet += mtk_wcn_consys_hw_reg_ctrl(1, co_clock_type);
+	harvest_snap("after-reg-ctrl-on", 1);
 
 	WMT_PLAT_INFO_FUNC("CONSYS-HW, hw_rst finish, eirq should be enabled after this step\n");
 	return iRet;
