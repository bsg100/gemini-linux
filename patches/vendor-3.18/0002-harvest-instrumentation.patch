+static VOID harvest_snap(const PINT8 tag)
+{
+	static VOID __iomem *harvest_1f00;
+	UINT32 v1f00 = 0, cpupcr = 0, pwr = 0, ack = 0, acks = 0;
+
+	if (!harvest_1f00)
+		harvest_1f00 = ioremap_nocache(0x10001f00, 0x4);
+	if (harvest_1f00)
+		v1f00 = CONSYS_REG_READ(harvest_1f00);
+	if (conn_reg.mcu_base)
+		cpupcr = CONSYS_REG_READ(conn_reg.mcu_base + CONSYS_CPUPCR_OFFSET);
+	if (conn_reg.spm_base) {
+		pwr = CONSYS_REG_READ(conn_reg.spm_base + CONSYS_TOP1_PWR_CTRL_OFFSET);
+		ack = CONSYS_REG_READ(conn_reg.spm_base + CONSYS_PWR_CONN_ACK_OFFSET);
+		acks = CONSYS_REG_READ(conn_reg.spm_base + CONSYS_PWR_CONN_ACK_S_OFFSET);
+	}
+	pr_info("HARVEST-SNAP[%s]: 0x10001f00=0x%08x CPUPCR=0x%08x TOP1_PWR=0x%08x ACK=0x%08x ACK_S=0x%08x\n",
+		tag, v1f00, cpupcr, pwr, ack, acks);
+}
