# USB gadget ethernet for SSH over the left USB-C port (see patches/v6.6/dts/0009).
#
# defconfig already has USB_MTU3=y, USB_GADGET=y and PHY_MTK_TPHY=y; this
# fragment forces peripheral-only mode (no XHCI/OTG/extcon needed for a
# device-role port, and dr_mode="peripheral" in the DTS) and builds in the
# legacy g_ether gadget so usb0 exists with zero userspace configuration.
# CDC ECM enumerates natively on macOS; the subset/RNDIS alt-configs that
# USB_ETH pulls in are harmless.
CONFIG_USB_MTU3=y
CONFIG_USB_MTU3_GADGET=y
CONFIG_PHY_MTK_TPHY=y
CONFIG_USB_GADGET=y
CONFIG_USB_ETH=y
