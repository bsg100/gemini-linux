# Phase 9: Gemini PDA touchscreen (Solomon SSD2092 on i2c4 @ 0x53).
#
# Chip hardware-identified 2026-07-16 (Stage A, build #263): with CTP_RST
# (GPIO68) high, 0x53 ACKs; matches the "Product ID: AUO599, IC Name:
# SSD2092" firmware header in the gemian vendor driver (archived at
# docs/vendor-touch-ssd20xx/).
#
# Driver:   patches/v6.6/input/0002-Input-add-solomon-ssd2092-touchscreen.patch
# DTS node: patches/v6.6/dts/0017-arm64-dts-mediatek-gemini-add-ssd2092-touchscreen-node.patch
# Polled INT (GPIO85 is EINT — pinctrl-mt6797 has no EINT support, B-11),
# same approach as the keyboard.
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_SSD2092=y
