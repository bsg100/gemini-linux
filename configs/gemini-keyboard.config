# Phase 6: Gemini PDA keyboard (AW9523B GPIO expander + gpio-matrix-keypad).
#
# Built-in (=y), not modules: the keyboard must work at the fbcon console
# login prompt, before any rootfs module loading.
#
# AW9523B driver: patches/v6.6/gpio/0001-gpio-add-awinic-aw9523b-gpio-expander.patch
# Polling mode:   patches/v6.6/input/0001-Input-matrix_keypad-add-polling-mode.patch
#   (needed because pinctrl-mt6797 has no EINT support — blockers.md B-11 —
#    so the AW9523B INT line on GPIO87 cannot deliver interrupts)
CONFIG_GPIO_AW9523B=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_MATRIX=y
