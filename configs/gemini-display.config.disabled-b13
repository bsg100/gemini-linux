# Phase 5 display bring-up.
#
# DISABLED 2026-07-05 (renamed so build.sh's *.config glob skips it):
# with COMMON_CLK_MT6797_MMSYS=y the kernel hard-hangs silently at ~0.52s,
# immediately after the last DSI/DRM activity — B-13's broken MM power domain
# (mtk-scpsys MT6797 domain table) wedges the bus on first MM-domain register
# access once the mm clk driver exists. Identical final line/timestamp in
# logs/2026-07-05-21-mmsys-fix-boot.log and -23-msdc0-hclk-fix-boot.log.
# Rename back to *.config only after B-13 is fixed.
#
# The Gemini's initramfs is the vendor 2019 Kali ramdisk with rdinit=/bin/sh
# (see gemini-cmdline.config) -- there is no modprobe/module path available
# in that minimal shell environment. Every driver in the display chain must
# therefore be built in (=y), not =m, or the panel will never light up
# regardless of whether the DT nodes are correct.
#
# defconfig ships DRM, DRM_KMS_HELPER, DRM_MEDIATEK and PHY_MTK_MIPI_DSI as
# modules, and does not enable DRM_PANEL_RENESAS_R63419 at all. Force all of
# them built-in here.
CONFIG_MTK_CMDQ=y
CONFIG_MTK_CMDQ_MBOX=y
CONFIG_MTK_MMSYS=y

# CONFIG_COMMON_CLK_MT6797_MMSYS is a tristate with no "default" in Kconfig,
# so defconfig leaves it (and its IMGSYS/VDECSYS/VENCSYS siblings) off.
# mtk-mmsys.c unconditionally registers a "clk-mt6797-mm" child platform
# device on probe; without this driver built in, that device has no driver
# to bind to, so CLK_MM_DSI0_MM_CLOCK (and every other mm-domain gate clock)
# never registers and the DSI "engine" clk consumer defers -EPROBE_DEFER
# forever. Built-in (=y), not =m, for the same rdinit=/bin/sh reason as the
# rest of this fragment.
CONFIG_COMMON_CLK_MT6797_MMSYS=y
CONFIG_COMMON_CLK_MT6797_IMGSYS=y
CONFIG_COMMON_CLK_MT6797_VDECSYS=y
CONFIG_COMMON_CLK_MT6797_VENCSYS=y

CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_MEDIATEK=y
CONFIG_PHY_MTK_MIPI_DSI=y
CONFIG_DRM_PANEL_RENESAS_R63419=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
