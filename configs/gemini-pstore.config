# Enable pstore/ramoops so kernel log output survives a crash, panic, or
# watchdog reset -- readable from /sys/fs/pstore/ after the *next* boot,
# independent of whether serial or USB networking was working at the time
# of the failure. The reserved-memory ramoops@44410000 node already exists
# in dts/0001 (matches the vendor's own pstore region for dual-boot safety)
# but CONFIG_PSTORE_RAM was never enabled to actually back it -- see
# blockers.md B-17, 2026-07-08.
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PSTORE_FTRACE=y
